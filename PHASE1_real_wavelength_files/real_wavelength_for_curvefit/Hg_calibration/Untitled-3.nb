          RowBox[{"Quiet", "@", 
           RowBox[{"NonlinearModelFit", "[", 
            RowBox[{"data", ",", "model", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"c", ",", "c0"}], "}"}], ",", 
               RowBox[{"{", 
