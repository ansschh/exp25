        RowBox[{"{", 
         RowBox[{
         "file", ",", "raw", ",", "data", ",", "xvals", ",", "yvals", ",", 
          "edgeN", ",", "c0", ",", "ampD0", ",", "ampH0", ",", "hGuess", ",", 
          "dGuess", ",", "sepGuess"}], "}"}], ",", 
        RowBox[{
         RowBox[{"file", "=", 
          RowBox[{"findFile", "[", 
           RowBox[{"spec", "[", "\"\<fileKey\>\"", "]"}], "]"}]}], ";", 
