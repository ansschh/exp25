                  RowBox[{"[", "j", "]"}], "]"}]}], "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"j", ",", 
                 RowBox[{"Length", "[", "peaks", "]"}]}], "}"}]}], "]"}]}], ";",
             "\[IndentingNewLine]", 
            RowBox[{"title", "=", 
             RowBox[{"category", "<>", "\"\<: \>\"", "<>", 
              RowBox[{"StringTake", "[", 
               RowBox[{"base", ",", 
                RowBox[{"UpTo", "[", "45", "]"}]}], "]"}]}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"figOut", "=", 
             RowBox[{"FileNameJoin", "[", 
              RowBox[{"{", 
               RowBox[{"figDir", ",", 
