 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fitOneHOnly", "[", "file_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "data", ",", "xvals", ",", "yvals", ",", "xmin", ",", "xmax", ",", 
        "edgeN", ",", "c0", ",", "d0", ",", "amp0", ",", "mu0", ",", "sig0", ",",
         "x0", ",", "fit", ",", "params", ",", "errs", ",", "resid", ",", 
        "rms", ",", "maxresid", ",", "fitPlot", ",", "residPlot", ",", 
        "combinedFig", ",", "outFile", ",", "centerGuess", ",", "label", ",", 
        "c", ",", "d", ",", "amp", ",", "mu", ",", "sig", ",", "x"}], "}"}], ",", 
      RowBox[{
       RowBox[{"data", "=", 
        RowBox[{"importNumeric", "[", "file", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "data", "]"}], "<", "8"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"<|", 
           RowBox[{
            RowBox[{"\"\<file\>\"", "->", 
             RowBox[{"FileNameTake", "[", "file", "]"}]}], ",", 
            RowBox[{"\"\<status\>\"", "->", "\"\<too_few_points\>\""}]}], 
           "|>"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"xvals", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yvals", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"xmin", ",", "xmax"}], "}"}], "=", 
        RowBox[{"MinMax", "[", "xvals", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"centerGuess", "=", 
        RowBox[{"Median", "[", "xvals", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"label", "=", 
        RowBox[{"balmerLabel", "[", "centerGuess", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"x0", "=", 
        RowBox[{"Mean", "[", 
         RowBox[{"{", 
          RowBox[{"xmin", ",", "xmax"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"edgeN", "=", 
        RowBox[{"Min", "[", 
         RowBox[{"5", ",", 
          RowBox[{"Length", "[", "yvals", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"c0", "=", 
        RowBox[{"Median", "[", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"Take", "[", 
            RowBox[{"yvals", ",", "edgeN"}], "]"}], ",", 
           RowBox[{"Take", "[", 
            RowBox[{"yvals", ",", 
             RowBox[{"-", "edgeN"}]}], "]"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"d0", "=", "0"}], ";", "\[IndentingNewLine]", 
       RowBox[{"amp0", "=", 
        RowBox[{
         RowBox[{"Max", "[", "yvals", "]"}], "-", "c0"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"mu0", "=", 
        RowBox[{"xvals", "[", 
         RowBox[{"[", 
          RowBox[{"First", "@", 
           RowBox[{"Ordering", "[", 
            RowBox[{"yvals", ",", 
             RowBox[{"-", "1"}]}], "]"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sig0", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"xmax", "-", "xmin"}], ")"}], "/", "8"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"fit", "=", 
        RowBox[{"Quiet", "@", 
         RowBox[{"NonlinearModelFit", "[", 
          RowBox[{"data", ",", 
           RowBox[{"c", "+", 
            RowBox[{"d", " ", 
             RowBox[{"(", 
              RowBox[{"x", "-", "x0"}], ")"}]}], "+", 
