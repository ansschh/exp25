 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"quadPeakCenter", "[", 
     RowBox[{"data_", ",", "i_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "sub", ",", "fit", ",", "a", ",", "b", ",", "c", ",", "center", ",", 
        "xmin", ",", "xmax", ",", "x"}], "}"}], ",", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"i", "<=", "1"}], "||", 
