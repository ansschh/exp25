           RowBox[{"data", ",", "0.06", ",", "0.035"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Length", "[", "peaks", "]"}], "==", "0"}], ",", 
           RowBox[{
            RowBox[{"Print", "[", 
             RowBox[{"\"\<No peaks detected in: \>\"", ",", 
              RowBox[{"FileNameTake", "[", "file", "]"}]}], "]"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"{", "}"}]}], ",", 
           RowBox[{
