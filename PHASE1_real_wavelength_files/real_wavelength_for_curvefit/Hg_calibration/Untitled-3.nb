          RowBox[{"file", "=", 
           RowBox[{"item", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"base", "=", 
           RowBox[{"FileBaseName", "[", "file", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"dataRaw", "=", 
           RowBox[{"importNumeric", "[", "file", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"data", "=", 
           RowBox[{"correctData", "[", "dataRaw", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"peaks", "=", 
           RowBox[{"detectPeaks", "[", 
            RowBox[{"data", ",", "0.06", ",", "0.035"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Length", "[", "peaks", "]"}], "==", "0"}], ",", 
            RowBox[{
             RowBox[{"Print", "[", 
              RowBox[{"\"\<No peaks detected in: \>\"", ",", 
