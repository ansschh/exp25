 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fitOneBoundedHD", "[", "spec_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "file", ",", "dataFull", ",", "data", ",", "xvals", ",", "yvals", ",", 
        "xmin", ",", "xmax", ",", "npts", ",", "x0", ",", "edgeN", ",", "c0", 
        ",", "d0", ",", "sepGuess", ",", "sigGuess", ",", "ampD0", ",", 
        "ampH0", ",", "x", ",", "c", ",", "d", ",", "ampD", ",", "ampH", ",", 
        "muD", ",", "sep", ",", "sig", ",", "model", ",", "constraints", ",", 
        "fit", ",", "params", ",", "errs", ",", "cov", ",", "r", ",", "rss", ",",
         "rms", ",", "maxres", ",", "muDVal", ",", "sepVal", ",", "muHVal", ",",
         "sigVal", ",", "ampDVal", ",", "ampHVal", ",", "muDSE", ",", "sepSE",
         ",", "muHSE", ",", "sigSE", ",", "lambdaDcorr", ",", "lambdaHcorr", ",",
         "deltaCorr", ",", "deltaCorrSE", ",", "baseline", ",", "dPeak", ",", 
        "hPeak", ",", "totalPlot", ",", "residPlot", ",", "outFile"}], "}"}], 
      ",", 
      RowBox[{
       RowBox[{"file", "=", 
        RowBox[{"findFile", "[", 
         RowBox[{"spec", "[", "\"\<fileKey\>\"", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"MissingQ", "[", "file", "]"}], ",", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<Missing file for \>\"", ",", 
            RowBox[{"spec", "[", "\"\<label\>\"", "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Return", "[", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<label\>\"", "->", 
              RowBox[{"spec", "[", "\"\<label\>\"", "]"}]}], ",", 
             RowBox[{"\"\<status\>\"", "->", "\"\<file_missing\>\""}]}], 
            "|>"}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"dataFull", "=", 
        RowBox[{"importNumeric", "[", "file", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"data", "=", 
        RowBox[{"cropData", "[", 
         RowBox[{"dataFull", ",", 
          RowBox[{"spec", "[", "\"\<window\>\"", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "data", "]"}], "<", "10"}], ",", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<Too few points for \>\"", ",", 
            RowBox[{"spec", "[", "\"\<label\>\"", "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Return", "[", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<label\>\"", "->", 
              RowBox[{"spec", "[", "\"\<label\>\"", "]"}]}], ",", 
             RowBox[{"\"\<status\>\"", "->", "\"\<too_few_points\>\""}]}], 
            "|>"}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"xvals", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yvals", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"xmin", ",", "xmax"}], "}"}], "=", 
        RowBox[{"MinMax", "[", "xvals", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"npts", "=", 
        RowBox[{"Length", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"x0", "=", 
        RowBox[{"Mean", "[", 
         RowBox[{"{", 
          RowBox[{"xmin", ",", "xmax"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"edgeN", "=", 
        RowBox[{"Min", "[", 
         RowBox[{"5", ",", 
          RowBox[{"Length", "[", "yvals", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"c0", "=", 
        RowBox[{"Median", "[", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"Take", "[", 
            RowBox[{"yvals", ",", "edgeN"}], "]"}], ",", 
           RowBox[{"Take", "[", 
            RowBox[{"yvals", ",", 
             RowBox[{"-", "edgeN"}]}], "]"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"d0", "=", "0"}], ";", "\[IndentingNewLine]", 
       RowBox[{"sepGuess", "=", 
        RowBox[{
         RowBox[{"spec", "[", "\"\<muHGuess\>\"", "]"}], "-", 
         RowBox[{"spec", "[", "\"\<muDGuess\>\"", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sigGuess", "=", 
        RowBox[{"Mean", "[", 
         RowBox[{"spec", "[", "\"\<sigRange\>\"", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ampD0", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"0.001", ",", 
          RowBox[{"ampNear", "[", 
           RowBox[{"data", ",", 
            RowBox[{"spec", "[", "\"\<muDGuess\>\"", "]"}], ",", "c0", ",", 
            "0.05"}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ampH0", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"0.001", ",", 
          RowBox[{"ampNear", "[", 
           RowBox[{"data", ",", 
            RowBox[{"spec", "[", "\"\<muHGuess\>\"", "]"}], ",", "c0", ",", 
            "0.05"}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Fitting \>\"", ",", 
         RowBox[{"spec", "[", "\"\<label\>\"", "]"}], 
         ",", "\"\< with bounded model, n = \>\"", ",", "npts"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<File: \>\"", ",", 
         RowBox[{"FileNameTake", "[", "file", "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Window: \>\"", ",", 
         RowBox[{"spec", "[", "\"\<window\>\"", "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Initial sep = \>\"", ",", "sepGuess"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"model", "=", 
        RowBox[{"c", "+", 
         RowBox[{"d", " ", 
          RowBox[{"(", 
           RowBox[{"x", "-", "x0"}], ")"}]}], "+", 
         RowBox[{"ampD", " ", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"x", "-", "muD"}], ")"}], "^", "2"}]}], "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", 
              RowBox[{"sig", "^", "2"}]}], ")"}]}], "]"}]}], "+", 
         RowBox[{"ampH", " ", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"x", "-", 
                RowBox[{"(", 
                 RowBox[{"muD", "+", "sep"}], ")"}]}], ")"}], "^", "2"}]}], "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", 
              RowBox[{"sig", "^", "2"}]}], ")"}]}], "]"}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"constraints", "=", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"spec", "[", "\"\<muDRange\>\"", "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}], "<=", "muD", "<=", 
           RowBox[{
            RowBox[{"spec", "[", "\"\<muDRange\>\"", "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"spec", "[", "\"\<sepRange\>\"", "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}], "<=", "sep", "<=", 
           RowBox[{
            RowBox[{"spec", "[", "\"\<sepRange\>\"", "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"spec", "[", "\"\<sigRange\>\"", "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}], "<=", "sig", "<=", 
           RowBox[{
            RowBox[{"spec", "[", "\"\<sigRange\>\"", "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", 
          RowBox[{"ampD", ">=", "0"}], ",", 
          RowBox[{"ampH", ">=", "0"}]}], "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"fit", "=", 
        RowBox[{"Quiet", "@", 
         RowBox[{"NonlinearModelFit", "[", 
          RowBox[{"data", ",", 
           RowBox[{"{", 
            RowBox[{"model", ",", "constraints"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"c", ",", "c0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"d", ",", "d0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"ampD", ",", "ampD0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"muD", ",", 
               RowBox[{"spec", "[", "\"\<muDGuess\>\"", "]"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"ampH", ",", "ampH0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"sep", ",", "sepGuess"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"sig", ",", "sigGuess"}], "}"}]}], "}"}], ",", "x", ",", 
           RowBox[{"Method", "->", "\"\<NMinimize\>\""}], ",", 
           RowBox[{"MaxIterations", "->", "20000"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"params", "=", 
        RowBox[{"fit", "[", "\"\<BestFitParameters\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Some", " ", "constrained", " ", "fits", " ", "may", " ", "not", " ", 
         "give", " ", "reliable", " ", "parameter", " ", 
         RowBox[{"errors", ".", "We"}], " ", "still", " ", "extract", " ", 
         "them", " ", "when", " ", 
         RowBox[{"available", "."}]}], "*)"}], 
       RowBox[{"errs", "=", 
        RowBox[{"Quiet", "@", 
         RowBox[{"Check", "[", 
          RowBox[{
           RowBox[{"fit", "[", "\"\<ParameterErrors\>\"", "]"}], ",", 
           RowBox[{"ConstantArray", "[", 
            RowBox[{
             RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}], ",", "7"}], "]"}]}],
           "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"cov", "=", 
        RowBox[{"Quiet", "@", 
         RowBox[{"Check", "[", 
          RowBox[{
           RowBox[{"fit", "[", "\"\<CovarianceMatrix\>\"", "]"}], ",", 
           RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"r", "=", 
        RowBox[{"data", "/.", " ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"xx_", ",", "yy_"}], "}"}], ":>", 
          RowBox[{"yy", "-", 
           RowBox[{"fit", "[", "xx", "]"}]}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rss", "=", 
        RowBox[{"Total", "[", 
         RowBox[{"r", "^", "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"rms", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"rss", "/", "npts"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"maxres", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"Abs", "[", "r", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"muDVal", "=", 
        RowBox[{"muD", "/.", " ", "params"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sepVal", "=", 
        RowBox[{"sep", "/.", " ", "params"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"muHVal", "=", 
        RowBox[{"muDVal", "+", "sepVal"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sigVal", "=", 
        RowBox[{"sig", "/.", " ", "params"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ampDVal", "=", 
        RowBox[{"ampD", "/.", " ", "params"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ampHVal", "=", 
        RowBox[{"ampH", "/.", " ", "params"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"muDSE", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"ListQ", "[", "errs", "]"}], ",", 
          RowBox[{"errs", "[", 
           RowBox[{"[", "4", "]"}], "]"}], ",", 
          RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sepSE", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"ListQ", "[", "errs", "]"}], ",", 
          RowBox[{"errs", "[", 
           RowBox[{"[", "6", "]"}], "]"}], ",", 
          RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"muHSE", "=", 
        RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sigSE", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"ListQ", "[", "errs", "]"}], ",", 
          RowBox[{"errs", "[", 
           RowBox[{"[", "7", "]"}], "]"}], ",", 
          RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"lambdaDcorr", "=", 
        RowBox[{"aCal", "+", 
         RowBox[{"bCal", " ", "muDVal"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"lambdaHcorr", "=", 
        RowBox[{"aCal", "+", 
         RowBox[{"bCal", " ", "muHVal"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"deltaCorr", "=", 
        RowBox[{"bCal", " ", "sepVal"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"deltaCorrSE", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"NumericQ", "[", "sepSE", "]"}], ",", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"bCal", " ", "sepSE"}], ")"}], "^", "2"}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"sepVal", " ", "sigmaB"}], ")"}], "^", "2"}]}], "]"}], ",", 
          RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"baseline", "[", "x_", "]"}], "=", 
        RowBox[{"Evaluate", "[", 
         RowBox[{
          RowBox[{"c", "+", 
           RowBox[{"d", " ", 
            RowBox[{"(", 
             RowBox[{"x", "-", "x0"}], ")"}]}]}], "/.", " ", "params"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"dPeak", "[", "x_", "]"}], "=", 
        RowBox[{"Evaluate", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"baseline", "[", "x", "]"}], "+", 
           RowBox[{"ampD", " ", 
            RowBox[{"Exp", "[", 
             RowBox[{
              RowBox[{"-", 
