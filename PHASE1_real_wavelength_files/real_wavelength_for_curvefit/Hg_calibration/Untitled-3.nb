             RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], "-", "base"}], ",", 
         RowBox[{
          RowBox[{"Max", "[", 
           RowBox[{"near", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], "-", "base"}]}], 
        "]"}]}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
