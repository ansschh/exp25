         "\[IndentingNewLine]", 
         RowBox[{"yvals", "=", 
          RowBox[{"data", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"edgeN", "=", 
          RowBox[{"Min", "[", 
           RowBox[{"5", ",", 
            RowBox[{"Length", "[", "yvals", "]"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"c0", "=", 
          RowBox[{"Median", "[", 
           RowBox[{"Join", "[", 
            RowBox[{
             RowBox[{"Take", "[", 
              RowBox[{"yvals", ",", "edgeN"}], "]"}], ",", 
             RowBox[{"Take", "[", 
              RowBox[{"yvals", ",", 
               RowBox[{"-", "edgeN"}]}], "]"}]}], "]"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
