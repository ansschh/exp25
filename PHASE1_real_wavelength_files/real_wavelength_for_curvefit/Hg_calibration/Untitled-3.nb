         "\[IndentingNewLine]", 
         RowBox[{"sepGuess", "=", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"sGuess", "/", "bCal"}], ")"}], " ", 
           RowBox[{"(", 
            RowBox[{"aCal", "+", 
             RowBox[{"bCal", " ", "hGuess"}]}], ")"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"dGuess", "=", 
          RowBox[{"hGuess", "-", "sepGuess"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"ampD0", "=", 
          RowBox[{"Max", "[", 
           RowBox[{"0.001", ",", 
            RowBox[{"ampNear", "[", 
             RowBox[{"data", ",", "dGuess", ",", "c0", ",", "0.05"}], "]"}]}],
            "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"ampH0", "=", 
          RowBox[{"Max", "[", 
           RowBox[{"0.001", ",", 
            RowBox[{"ampNear", "[", 
             RowBox[{"data", ",", "hGuess", ",", "c0", ",", "0.05"}], "]"}]}],
            "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<spec\>\"", "->", "spec"}], ",", 
           RowBox[{"\"\<file\>\"", "->", "file"}], ",", 
           RowBox[{"\"\<data\>\"", "->", "data"}], ",", 
           RowBox[{"\"\<x0\>\"", "->", 
