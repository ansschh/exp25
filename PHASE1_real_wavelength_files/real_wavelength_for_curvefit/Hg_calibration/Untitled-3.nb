    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "near", "}"}], ",", 
      RowBox[{
       RowBox[{"near", "=", 
        RowBox[{"Select", "[", 
         RowBox[{"data", ",", 
