         ",", "d0", ",", "ampD0", ",", "ampH0", ",", "sepGuess", ",", 
        "scaleGuess", ",", "x", ",", "c", ",", "d", ",", "aD", ",", "aH", ",",
         "zD", ",", "zSep", ",", "zScale", ",", "muDExpr", ",", "sepExpr", ",",
