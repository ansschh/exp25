      ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"Length", "[", "files", "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"item", ",", 
        RowBox[{"{", 
         RowBox[{"files", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "}"}]}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
