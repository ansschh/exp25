                  "<>", "\"\<.pdf\>\""}]}], "}"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"plotIdentityMap", "[", 
              RowBox[{"data", ",", "peaks", ",", "title", ",", "figOut"}], 
              "]"}], ";", "\[IndentingNewLine]", "rows"}]}], "]"}]}]}], "]"}],
        ",", 
       RowBox[{"{", 
        RowBox[{"item", ",", "files"}], "}"}]}], "]"}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"If", "[", 
