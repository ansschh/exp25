      RowBox[{"{", 
       RowBox[{
       "data", ",", "xvals", ",", "yvals", ",", "s", ",", "res", ",", "rms", ",",
         "maxres", ",", "mpme"}], "}"}], ",", 
      RowBox[{
       RowBox[{"data", "=", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"#", "[", "\"\<lambdaH_corr_nm\>\"", "]"}], ",", 
             RowBox[{"#", "[", "\"\<delta_corr_nm\>\"", "]"}]}], "}"}], "&"}],
           "/@", "rows"}], ")"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"xvals", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yvals", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"s", "=", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"xvals", " ", "yvals"}], "]"}], "/", 
         RowBox[{"Total", "[", 
          RowBox[{"xvals", "^", "2"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"res", "=", 
        RowBox[{"yvals", "-", 
         RowBox[{"s", " ", "xvals"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"rms", "=", 
        RowBox[{"Sqrt", "[", 
