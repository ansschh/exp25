           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"c", ",", "c0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"d", ",", "d0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"amp", ",", "amp0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"mu", ",", "mu0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"sig", ",", "sig0"}], "}"}]}], "}"}], ",", "x", ",", 
           RowBox[{"MaxIterations", "->", "10000"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"params", "=", 
        RowBox[{"fit", "[", "\"\<BestFitParameters\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
