 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fitOneFastHD", "[", "spec_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "file", ",", "dataFull", ",", "data", ",", "xvals", ",", "yvals", ",", 
        "xmin", ",", "xmax", ",", "npts", ",", "x0", ",", "edgeN", ",", "c0", 
        ",", "d0", ",", "sepGuess", ",", "sigGuess", ",", "ampD0", ",", 
        "ampH0", ",", "x", ",", "c", ",", "d", ",", "aD", ",", "aH", ",", 
        "zD", ",", "zSep", ",", "zSig", ",", "muDExpr", ",", "sepExpr", ",", 
        "muHExpr", ",", "sigExpr", ",", "model", ",", "fit", ",", "params", ",",
         "errs", ",", "cov", ",", "rawNames", ",", "r", ",", "rss", ",", 
        "rms", ",", "maxres", ",", "muDVal", ",", "sepVal", ",", "muHVal", ",",
         "sigVal", ",", "ampDVal", ",", "ampHVal", ",", "derivSE", ",", 
        "muDSE", ",", "sepSE", ",", "muHSE", ",", "sigSE", ",", "lambdaDcorr",
         ",", "lambdaHcorr", ",", "deltaCorr", ",", "deltaCorrSE", ",", 
        "baseline", ",", "dPeak", ",", "hPeak", ",", "totalPlot", ",", 
        "residPlot", ",", "outFile"}], "}"}], ",", 
      RowBox[{
       RowBox[{"file", "=", 
        RowBox[{"findFile", "[", 
         RowBox[{"spec", "[", "\"\<fileKey\>\"", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"MissingQ", "[", "file", "]"}], ",", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<Missing file for \>\"", ",", 
            RowBox[{"spec", "[", "\"\<label\>\"", "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Return", "[", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<label\>\"", "->", 
              RowBox[{"spec", "[", "\"\<label\>\"", "]"}]}], ",", 
             RowBox[{"\"\<status\>\"", "->", "\"\<file_missing\>\""}]}], 
            "|>"}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"dataFull", "=", 
        RowBox[{"importNumeric", "[", "file", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"data", "=", 
        RowBox[{"cropData", "[", 
         RowBox[{"dataFull", ",", 
          RowBox[{"spec", "[", "\"\<window\>\"", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "data", "]"}], "<", "10"}], ",", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<Too few points for \>\"", ",", 
            RowBox[{"spec", "[", "\"\<label\>\"", "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Return", "[", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<label\>\"", "->", 
              RowBox[{"spec", "[", "\"\<label\>\"", "]"}]}], ",", 
             RowBox[{"\"\<status\>\"", "->", "\"\<too_few_points\>\""}]}], 
            "|>"}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"xvals", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yvals", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"xmin", ",", "xmax"}], "}"}], "=", 
        RowBox[{"MinMax", "[", "xvals", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"npts", "=", 
        RowBox[{"Length", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"x0", "=", 
        RowBox[{"Mean", "[", 
         RowBox[{"{", 
          RowBox[{"xmin", ",", "xmax"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"edgeN", "=", 
        RowBox[{"Min", "[", 
         RowBox[{"5", ",", 
          RowBox[{"Length", "[", "yvals", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"c0", "=", 
        RowBox[{"Median", "[", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"Take", "[", 
            RowBox[{"yvals", ",", "edgeN"}], "]"}], ",", 
           RowBox[{"Take", "[", 
            RowBox[{"yvals", ",", 
             RowBox[{"-", "edgeN"}]}], "]"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"d0", "=", "0"}], ";", "\[IndentingNewLine]", 
       RowBox[{"sepGuess", "=", 
        RowBox[{
         RowBox[{"spec", "[", "\"\<muHGuess\>\"", "]"}], "-", 
         RowBox[{"spec", "[", "\"\<muDGuess\>\"", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sigGuess", "=", 
        RowBox[{"Mean", "[", 
         RowBox[{"spec", "[", "\"\<sigRange\>\"", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ampD0", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"0.001", ",", 
          RowBox[{"ampNear", "[", 
           RowBox[{"data", ",", 
            RowBox[{"spec", "[", "\"\<muDGuess\>\"", "]"}], ",", "c0", ",", 
            "0.05"}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"ampH0", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"0.001", ",", 
          RowBox[{"ampNear", "[", 
           RowBox[{"data", ",", 
            RowBox[{"spec", "[", "\"\<muHGuess\>\"", "]"}], ",", "c0", ",", 
            "0.05"}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Fitting \>\"", ",", 
         RowBox[{"spec", "[", "\"\<label\>\"", "]"}], 
         ",", "\"\< fast bounded, n = \>\"", ",", "npts"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"muDExpr", "=", 
        RowBox[{"bound", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"spec", "[", "\"\<muDRange\>\"", "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"spec", "[", "\"\<muDRange\>\"", "]"}], "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", "zD"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sepExpr", "=", 
        RowBox[{"bound", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"spec", "[", "\"\<sepRange\>\"", "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"spec", "[", "\"\<sepRange\>\"", "]"}], "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", "zSep"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"muHExpr", "=", 
        RowBox[{"muDExpr", "+", "sepExpr"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sigExpr", "=", 
        RowBox[{"bound", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"spec", "[", "\"\<sigRange\>\"", "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", 
          RowBox[{
           RowBox[{"spec", "[", "\"\<sigRange\>\"", "]"}], "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", "zSig"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"model", "=", 
        RowBox[{"c", "+", 
         RowBox[{"d", " ", 
          RowBox[{"(", 
           RowBox[{"x", "-", "x0"}], ")"}]}], "+", 
         RowBox[{
          RowBox[{"aD", "^", "2"}], " ", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"x", "-", "muDExpr"}], ")"}], "^", "2"}]}], "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", 
              RowBox[{"sigExpr", "^", "2"}]}], ")"}]}], "]"}]}], "+", 
