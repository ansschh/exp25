      RowBox[{"k_", ":", "2"}]}], "]"}], ":=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Mean", "[", 
       RowBox[{"y", "[", 
        RowBox[{"[", 
         RowBox[{
          RowBox[{"Max", "[", 
           RowBox[{"1", ",", 
            RowBox[{"i", "-", "k"}]}], "]"}], ";;", 
          RowBox[{"Min", "[", 
           RowBox[{
            RowBox[{"Length", "[", "y", "]"}], ",", 
            RowBox[{"i", "+", "k"}]}], "]"}]}], "]"}], "]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"Length", "[", "y", "]"}]}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"selectSeparatedPeaks", "[", 
     RowBox[{"inds_", ",", "xvals_", ",", "yvals_", ",", "minSep_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"sorted", ",", 
        RowBox[{"kept", "=", 
         RowBox[{"{", "}"}]}]}], "}"}], ",", 
      RowBox[{
       RowBox[{"sorted", "=", 
        RowBox[{"Reverse", "@", 
         RowBox[{"SortBy", "[", 
          RowBox[{"inds", ",", 
           RowBox[{
            RowBox[{"yvals", "[", 
             RowBox[{"[", "#", "]"}], "]"}], "&"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Do", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"AllTrue", "[", 
            RowBox[{"kept", ",", 
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{
                 RowBox[{"xvals", "[", 
                  RowBox[{"[", "idx", "]"}], "]"}], "-", 
                 RowBox[{"xvals", "[", 
                  RowBox[{"[", "#", "]"}], "]"}]}], "]"}], ">", "minSep"}], 
              "&"}]}], "]"}], ",", 
           RowBox[{"AppendTo", "[", 
            RowBox[{"kept", ",", "idx"}], "]"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"idx", ",", "sorted"}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Sort", "[", "kept", "]"}]}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"quadPeakCenter", "[", 
     RowBox[{"data_", ",", "i_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "sub", ",", "fit", ",", "a", ",", "b", ",", "center", ",", "xmin", ",",
         "xmax", ",", "x"}], "}"}], ",", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"i", "<=", "1"}], "||", 
          RowBox[{"i", ">=", 
           RowBox[{"Length", "[", "data", "]"}]}]}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"data", "[", 
           RowBox[{"[", 
            RowBox[{"i", ",", "1"}], "]"}], "]"}], "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sub", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"i", "-", "1"}], ";;", 
           RowBox[{"i", "+", "1"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"xmin", ",", "xmax"}], "}"}], "=", 
        RowBox[{"MinMax", "[", 
         RowBox[{"sub", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"fit", "=", 
        RowBox[{"Quiet", "@", 
         RowBox[{"Fit", "[", 
          RowBox[{"sub", ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", "x", ",", 
             RowBox[{"x", "^", "2"}]}], "}"}], ",", "x"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"b", "=", 
        RowBox[{"Coefficient", "[", 
         RowBox[{"fit", ",", "x", ",", "1"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"a", "=", 
        RowBox[{"Coefficient", "[", 
         RowBox[{"fit", ",", "x", ",", "2"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"NumericQ", "[", "a", "]"}], "&&", 
          RowBox[{"a", "<", "0"}]}], ",", 
         RowBox[{
          RowBox[{"center", "=", 
           RowBox[{
            RowBox[{"-", "b"}], "/", 
            RowBox[{"(", 
             RowBox[{"2", " ", "a"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"xmin", "<=", "center", "<=", "xmax"}], ",", "center", ",", 
            RowBox[{"data", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}]}], "]"}]}], ",", 
         RowBox[{"data", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "1"}], "]"}], "]"}]}], "]"}]}]}], "]"}]}], ";"}],
   "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"detectPeaks", "[", 
     RowBox[{"data_", ",", 
      RowBox[{"minPromFrac_", ":", "0.06"}], ",", 
      RowBox[{"minSep_", ":", "0.035"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "xvals", ",", "yvals", ",", "ys", ",", "baseline", ",", "dyn", ",", 
        "thresh", ",", "local", ",", "selected"}], "}"}], ",", 
      RowBox[{
       RowBox[{"xvals", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yvals", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"ys", "=", 
        RowBox[{"smoothList", "[", 
         RowBox[{"yvals", ",", "2"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"baseline", "=", 
        RowBox[{"Quantile", "[", 
         RowBox[{"yvals", ",", "0.10"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"dyn", "=", 
        RowBox[{
         RowBox[{"Max", "[", "yvals", "]"}], "-", "baseline"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"thresh", "=", 
        RowBox[{"baseline", "+", 
         RowBox[{"minPromFrac", " ", "dyn"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"dyn", "<=", "0"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"{", "}"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"local", "=", 
        RowBox[{"Select", "[", 
         RowBox[{
          RowBox[{"Range", "[", 
           RowBox[{"2", ",", 
            RowBox[{
             RowBox[{"Length", "[", "ys", "]"}], "-", "1"}]}], "]"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"ys", "[", 
              RowBox[{"[", "#", "]"}], "]"}], ">=", 
             RowBox[{"ys", "[", 
              RowBox[{"[", 
               RowBox[{"#", "-", "1"}], "]"}], "]"}]}], "&&", 
            RowBox[{
             RowBox[{"ys", "[", 
              RowBox[{"[", "#", "]"}], "]"}], ">=", 
             RowBox[{"ys", "[", 
              RowBox[{"[", 
               RowBox[{"#", "+", "1"}], "]"}], "]"}]}], "&&", 
            RowBox[{
             RowBox[{"ys", "[", 
              RowBox[{"[", "#", "]"}], "]"}], ">", "thresh"}]}], "&"}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"selected", "=", 
        RowBox[{"selectSeparatedPeaks", "[", 
         RowBox[{"local", ",", "xvals", ",", "ys", ",", "minSep"}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<peak_nm\>\"", "->", 
            RowBox[{"quadPeakCenter", "[", 
             RowBox[{"data", ",", "i"}], "]"}]}], ",", 
           RowBox[{"\"\<nearest_sample_nm\>\"", "->", 
            RowBox[{"xvals", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], ",", 
           RowBox[{"\"\<signal_V\>\"", "->", 
            RowBox[{"yvals", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], ",", 
           RowBox[{"\"\<baseline_V\>\"", "->", "baseline"}], ",", 
           RowBox[{"\"\<height_over_baseline_V\>\"", "->", 
            RowBox[{
             RowBox[{"yvals", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "-", "baseline"}]}]}], "|>"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "selected"}], "}"}]}], "]"}]}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"matchPeak", "[", "peakNm_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"best", ",", "delta", ",", "confidence"}], "}"}], ",", 
      RowBox[{
       RowBox[{"best", "=", 
        RowBox[{"First", "@", 
         RowBox[{"SortBy", "[", 
          RowBox[{"candidateLines", ",", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"#", "[", "\"\<apparent_nm\>\"", "]"}], "-", "peakNm"}],
              "]"}], "&"}]}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"delta", "=", 
        RowBox[{"peakNm", "-", 
         RowBox[{"best", "[", "\"\<apparent_nm\>\"", "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"confidence", "=", 
        RowBox[{"Which", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", "delta", "]"}], "<=", "0.035"}], 
          ",", "\"\<strong\>\"", ",", 
          RowBox[{
           RowBox[{"Abs", "[", "delta", "]"}], "<=", "0.080"}], 
          ",", "\"\<possible\>\"", ",", "True", ",", "\"\<unmatched\>\""}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<matched_candidate\>\"", "->", 
          RowBox[{"best", "[", "\"\<candidate\>\"", "]"}]}], ",", 
         RowBox[{"\"\<matched_species\>\"", "->", 
          RowBox[{"best", "[", "\"\<species\>\"", "]"}]}], ",", 
         RowBox[{"\"\<candidate_nm\>\"", "->", 
          RowBox[{"best", "[", "\"\<apparent_nm\>\"", "]"}]}], ",", 
         RowBox[{"\"\<delta_nm\>\"", "->", "delta"}], ",", 
         RowBox[{"\"\<confidence\>\"", "->", "confidence"}], ",", 
         RowBox[{"\"\<note\>\"", "->", 
          RowBox[{"best", "[", "\"\<note\>\"", "]"}]}]}], "|>"}]}]}], "]"}]}],
    ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
