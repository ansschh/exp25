          RowBox[{"res", "^", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"maxres", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"Abs", "[", "res", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"mpme", "=", 
        RowBox[{"0.500", "/", "s"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<fit_label\>\"", "->", "label"}], ",", 
         RowBox[{"\"\<n_points\>\"", "->", 
          RowBox[{"Length", "[", "rows", "]"}]}], ",", 
         RowBox[{"\"\<slope\>\"", "->", "s"}], ",", 
         RowBox[{"\"\<mp_over_me\>\"", "->", "mpme"}], ",", 
         RowBox[{"\"\<RMS_residual_nm\>\"", "->", "rms"}], ",", 
