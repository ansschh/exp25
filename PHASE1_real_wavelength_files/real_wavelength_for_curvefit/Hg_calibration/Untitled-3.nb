       "\[IndentingNewLine]", 
       RowBox[{"c", "=", 
        RowBox[{"Coefficient", "[", 
         RowBox[{"fit", ",", "x", ",", "0"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"b", "=", 
