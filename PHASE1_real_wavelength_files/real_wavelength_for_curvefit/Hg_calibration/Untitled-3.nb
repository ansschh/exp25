            RowBox[{"(", 
             RowBox[{"2", " ", 
              RowBox[{"sigExpr", "^", "2"}]}], ")"}]}], "]"}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"fit", "=", 
        RowBox[{"TimeConstrained", "[", 
