         RowBox[{"file", "=", 
          RowBox[{"item", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"base", "=", 
          RowBox[{"FileBaseName", "[", "file", "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"dataRaw", "=", 
          RowBox[{"importNumeric", "[", "file", "]"}]}], ";", 
         "\[IndentingNewLine]", 
