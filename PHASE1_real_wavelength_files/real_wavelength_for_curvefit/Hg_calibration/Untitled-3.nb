 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fitOneHg", "[", "spec_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "file", ",", "dataFull", ",", "data", ",", "xvals", ",", "yvals", ",", 
        "xmin", ",", "xmax", ",", "c0", ",", "d0", ",", "amp0", ",", "mu0", ",",
         "sig0", ",", "x0", ",", "edgeN", ",", "fit", ",", "params", ",", 
        "errs", ",", "resid", ",", "rms", ",", "maxresid", ",", "fitPlot", ",",
         "residPlot", ",", "table", ",", "report", ",", "outFile", ",", "c", ",",
         "d", ",", "amp", ",", "mu", ",", "sig", ",", "x"}], "}"}], ",", 
      RowBox[{
       RowBox[{"file", "=", 
        RowBox[{"findFile", "[", 
         RowBox[{"spec", "[", "\"\<fileKey\>\"", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"MissingQ", "[", "file", "]"}], ",", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<Missing file for \>\"", ",", 
            RowBox[{"spec", "[", "\"\<id\>\"", "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Return", "[", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<id\>\"", "->", 
              RowBox[{"spec", "[", "\"\<id\>\"", "]"}]}], ",", 
             RowBox[{"\"\<status\>\"", "->", "\"\<file_missing\>\""}]}], 
            "|>"}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"dataFull", "=", 
        RowBox[{"importNumeric", "[", "file", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"data", "=", 
        RowBox[{"cropData", "[", 
         RowBox[{"dataFull", ",", 
          RowBox[{"spec", "[", "\"\<window\>\"", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "data", "]"}], "<", "8"}], ",", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<Too few points for \>\"", ",", 
            RowBox[{"spec", "[", "\"\<id\>\"", "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Return", "[", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<id\>\"", "->", 
              RowBox[{"spec", "[", "\"\<id\>\"", "]"}]}], ",", 
             RowBox[{"\"\<status\>\"", "->", "\"\<too_few_points\>\""}]}], 
            "|>"}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"xvals", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yvals", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"xmin", ",", "xmax"}], "}"}], "=", 
        RowBox[{"MinMax", "[", "xvals", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"x0", "=", 
        RowBox[{"Mean", "[", 
         RowBox[{"{", 
          RowBox[{"xmin", ",", "xmax"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"edgeN", "=", 
        RowBox[{"Min", "[", 
         RowBox[{"5", ",", 
          RowBox[{"Length", "[", "yvals", "]"}]}], "]"}]}], ";", "\n", "\t", 
       RowBox[{"c0", "=", 
        RowBox[{"Median", "[", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"Take", "[", 
            RowBox[{"yvals", ",", "edgeN"}], "]"}], ",", 
           RowBox[{"Take", "[", 
            RowBox[{"yvals", ",", 
             RowBox[{"-", "edgeN"}]}], "]"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"d0", "=", "0"}], ";", "\[IndentingNewLine]", 
       RowBox[{"amp0", "=", 
        RowBox[{
         RowBox[{"Max", "[", "yvals", "]"}], "-", "c0"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"mu0", "=", 
        RowBox[{"xvals", "[", 
         RowBox[{"[", 
          RowBox[{"First", "@", 
           RowBox[{"Ordering", "[", 
            RowBox[{"yvals", ",", 
             RowBox[{"-", "1"}]}], "]"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sig0", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"xmax", "-", "xmin"}], ")"}], "/", "6"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"fit", "=", 
        RowBox[{"Quiet", "@", 
         RowBox[{"NonlinearModelFit", "[", 
          RowBox[{"data", ",", 
           RowBox[{"c", "+", 
            RowBox[{"d", " ", 
             RowBox[{"(", 
              RowBox[{"x", "-", "x0"}], ")"}]}], "+", 
            RowBox[{"amp", " ", 
             RowBox[{"Exp", "[", 
              RowBox[{
               RowBox[{"-", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"x", "-", "mu"}], ")"}], "^", "2"}]}], "/", 
               RowBox[{"(", 
                RowBox[{"2", " ", 
                 RowBox[{"sig", "^", "2"}]}], ")"}]}], "]"}]}]}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"c", ",", "c0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"d", ",", "d0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"amp", ",", "amp0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"mu", ",", "mu0"}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"sig", ",", "sig0"}], "}"}]}], "}"}], ",", "x", ",", 
           RowBox[{"MaxIterations", "->", "10000"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"params", "=", 
        RowBox[{"fit", "[", "\"\<BestFitParameters\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"errs", "=", 
        RowBox[{"fit", "[", "\"\<ParameterErrors\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"resid", "=", 
        RowBox[{"data", "/.", " ", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"xx_", ",", "yy_"}], "}"}], ":>", 
          RowBox[{"{", 
           RowBox[{"xx", ",", 
            RowBox[{"yy", "-", 
             RowBox[{"fit", "[", "xx", "]"}]}]}], "}"}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rms", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"Mean", "[", 
          RowBox[{
           RowBox[{"resid", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "2"}], "]"}], "]"}], "^", "2"}], "]"}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"maxresid", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"Abs", "[", 
          RowBox[{"resid", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "2"}], "]"}], "]"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"fitPlot", "=", 
        RowBox[{"Show", "[", 
         RowBox[{
          RowBox[{"ListPlot", "[", 
           RowBox[{"data", ",", 
            RowBox[{"Frame", "->", "True"}], ",", 
            RowBox[{"Axes", "->", "False"}], ",", 
            RowBox[{"PlotMarkers", "->", 
             RowBox[{"{", 
              RowBox[{"Automatic", ",", "8"}], "}"}]}], ",", 
            RowBox[{"PlotRange", "->", "All"}], ",", 
            RowBox[{"ImageSize", "->", "750"}], ",", 
            RowBox[{"FrameLabel", "->", 
             RowBox[{"{", 
              RowBox[{"\"\<Wavelength (nm)\>\"", ",", "\"\<Signal (V)\>\""}], 
              "}"}]}], ",", 
            RowBox[{"PlotLabel", "->", 
             RowBox[{"Style", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"spec", "[", "\"\<id\>\"", "]"}], 
                "<>", "\"\<: Gaussian + linear background\>\""}], ",", "14", ",",
                "Black"}], "]"}]}]}], "]"}], ",", 
          RowBox[{"Plot", "[", 
           RowBox[{
            RowBox[{"fit", "[", "x", "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"x", ",", "xmin", ",", "xmax"}], "}"}], ",", 
            RowBox[{"PlotStyle", "->", 
             RowBox[{"{", 
              RowBox[{"Red", ",", "Thick"}], "}"}]}]}], "]"}]}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"residPlot", "=", 
        RowBox[{"ListPlot", "[", 
         RowBox[{"resid", ",", 
          RowBox[{"Frame", "->", "True"}], ",", 
          RowBox[{"Axes", "->", "False"}], ",", 
          RowBox[{"PlotMarkers", "->", 
           RowBox[{"{", 
            RowBox[{"Automatic", ",", "8"}], "}"}]}], ",", 
          RowBox[{"PlotRange", "->", "All"}], ",", 
          RowBox[{"ImageSize", "->", "750"}], ",", 
          RowBox[{"FrameLabel", "->", 
           RowBox[{"{", 
            RowBox[{"\"\<Wavelength (nm)\>\"", ",", "\"\<Residual (V)\>\""}], 
            "}"}]}], ",", 
          RowBox[{"PlotLabel", "->", 
           RowBox[{"Style", "[", 
            RowBox[{"\"\<Residuals\>\"", ",", "13", ",", "Black"}], "]"}]}], ",", 
          RowBox[{"GridLines", "->", 
           RowBox[{"{", 
            RowBox[{"None", ",", 
             RowBox[{"{", "0", "}"}]}], "}"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"table", "=", 
        RowBox[{"Grid", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             
             RowBox[{"\"\<parameter\>\"", ",", "\"\<estimate\>\"", 
              ",", "\"\<standard error\>\""}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"\"\<c\>\"", ",", 
              RowBox[{"c", "/.", " ", "params"}], ",", 
              RowBox[{"errs", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"\"\<d\>\"", ",", 
              RowBox[{"d", "/.", " ", "params"}], ",", 
              RowBox[{"errs", "[", 
               RowBox[{"[", "2", "]"}], "]"}]}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"\"\<amp\>\"", ",", 
              RowBox[{"amp", "/.", " ", "params"}], ",", 
              RowBox[{"errs", "[", 
