 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"zeroInterceptStats", "[", "pipeline_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "rows", ",", "cleanRows", ",", "xvals", ",", "yvals", ",", "sigmas", ",",
         "n", ",", "s", ",", "res", ",", "rms", ",", "maxres", ",", "dof", ",",
         "sigmaRes", ",", "sSE", ",", "mpme", ",", "mpmeSE", ",", "freeFit", ",",
         "freeParams", ",", "freeErrs", ",", "qFree", ",", "qFreeSE", ",", 
        "sFree", ",", "sFreeSE", ",", "mpmeFree", ",", "mpmeFreeSE", ",", 
        "useWeights", ",", "weights", ",", "sw", ",", "resw", ",", "chi2", ",",
         "scale", ",", "swSEFormal", ",", "swSEScaled", ",", "mpmeW", ",", 
        "mpmeWSE"}], "}"}], ",", 
      RowBox[{
       RowBox[{"rows", "=", 
        RowBox[{"pipeline", "[", "\"\<rows\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"cleanRows", "=", 
        RowBox[{"Select", "[", 
         RowBox[{"rows", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"numQ", "[", 
             RowBox[{"#", "[", "\"\<lambdaH\>\"", "]"}], "]"}], "&&", 
            RowBox[{"numQ", "[", 
             RowBox[{"#", "[", "\"\<delta\>\"", "]"}], "]"}]}], "&"}]}], 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"xvals", "=", 
        RowBox[{"cleanRows", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "\"\<lambdaH\>\""}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yvals", "=", 
        RowBox[{"cleanRows", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "\"\<delta\>\""}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sigmas", "=", 
        RowBox[{"cleanRows", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "\"\<sigma\>\""}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "cleanRows", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"s", "=", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"xvals", " ", "yvals"}], "]"}], "/", 
         RowBox[{"Total", "[", 
          RowBox[{"xvals", "^", "2"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"res", "=", 
        RowBox[{"yvals", "-", 
         RowBox[{"s", " ", "xvals"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"rms", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"Mean", "[", 
          RowBox[{"res", "^", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"maxres", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"Abs", "[", "res", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dof", "=", 
        RowBox[{"n", "-", "1"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sigmaRes", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"dof", ">", "0"}], ",", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"Total", "[", 
             RowBox[{"res", "^", "2"}], "]"}], "/", "dof"}], "]"}], ",", 
          RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sSE", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"numQ", "[", "sigmaRes", "]"}], ",", 
          RowBox[{"sigmaRes", "/", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"Total", "[", 
             RowBox[{"xvals", "^", "2"}], "]"}], "]"}]}], ",", 
          RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"mpme", "=", 
        RowBox[{"0.500", "/", "s"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"mpmeSE", "=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"numQ", "[", "sSE", "]"}], ",", 
          RowBox[{"0.500", " ", 
           RowBox[{"sSE", "/", 
            RowBox[{"s", "^", "2"}]}]}], ",", 
          RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"n", ">=", "3"}], ",", 
         RowBox[{
          RowBox[{"freeFit", "=", 
           RowBox[{"LinearModelFit", "[", 
            RowBox[{
             RowBox[{"Transpose", "[", 
              RowBox[{"{", 
               RowBox[{"xvals", ",", "yvals"}], "}"}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"1", ",", "x"}], "}"}], ",", "x"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"freeParams", "=", 
           RowBox[{"freeFit", "[", "\"\<BestFitParameters\>\"", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"freeErrs", "=", 
           RowBox[{"freeFit", "[", "\"\<ParameterErrors\>\"", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"qFree", "=", 
           RowBox[{"freeParams", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"qFreeSE", "=", 
           RowBox[{"freeErrs", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"sFree", "=", 
           RowBox[{"freeParams", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"sFreeSE", "=", 
           RowBox[{"freeErrs", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"mpmeFree", "=", 
           RowBox[{"0.500", "/", "sFree"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"mpmeFreeSE", "=", 
           RowBox[{"0.500", " ", 
            RowBox[{"sFreeSE", "/", 
             RowBox[{"sFree", "^", "2"}]}]}]}], ";"}], ",", 
         RowBox[{
          RowBox[{"qFree", "=", 
           RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"qFreeSE", "=", 
           RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"sFree", "=", 
           RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"sFreeSE", "=", 
           RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"mpmeFree", "=", 
           RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"mpmeFreeSE", "=", 
           RowBox[{"Missing", "[", "\"\<NA\>\"", "]"}]}], ";"}]}], "]"}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"useWeights", "=", 
        RowBox[{
         RowBox[{"VectorQ", "[", 
          RowBox[{"sigmas", ",", "numQ"}], "]"}], "&&", 
         RowBox[{
          RowBox[{"Min", "[", "sigmas", "]"}], ">", "0"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{"useWeights", ",", 
         RowBox[{
          RowBox[{"weights", "=", 
           RowBox[{"1", "/", 
            RowBox[{"sigmas", "^", "2"}]}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"sw", "=", 
           RowBox[{
            RowBox[{"Total", "[", 
