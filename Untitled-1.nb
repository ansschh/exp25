 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fitOneHg", "[", "spec_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "file", ",", "dataFull", ",", "dataFit", ",", "window", ",", "trueWL", 
        ",", "id", ",", "report", ",", "titledReport", ",", "outFile", ",", 
        "params", ",", "result"}], "}"}], ",", 
      RowBox[{
       RowBox[{"id", "=", 
        RowBox[{"spec", "[", "\"\<id\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"trueWL", "=", 
        RowBox[{"spec", "[", "\"\<trueWL\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"window", "=", 
        RowBox[{"spec", "[", "\"\<fitWindow\>\"", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"file", "=", 
        RowBox[{"findFile", "[", 
         RowBox[{"spec", "[", "\"\<fileKey\>\"", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"MissingQ", "[", "file", "]"}], ",", 
         RowBox[{"Return", "[", 
          RowBox[{"<|", 
           RowBox[{
            RowBox[{"\"\<id\>\"", "->", "id"}], ",", 
            RowBox[{"\"\<status\>\"", "->", "\"\<file_missing\>\""}], ",", 
            RowBox[{"\"\<trueWL_nm\>\"", "->", "trueWL"}], ",", 
            RowBox[{"\"\<observed_mu_nm\>\"", "->", 
             RowBox[{"Missing", "[", "\"\<NoFit\>\"", "]"}]}], ",", 
            RowBox[{"\"\<sigmu_nm\>\"", "->", 
             RowBox[{"Missing", "[", "\"\<NoFit\>\"", "]"}]}]}], "|>"}], 
          "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"dataFull", "=", 
        RowBox[{"importNumeric", "[", "file", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dataFit", "=", 
        RowBox[{"cropData", "[", 
         RowBox[{"dataFull", ",", "window"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "dataFit", "]"}], "<", "8"}], ",", 
         RowBox[{
          RowBox[{"Print", "[", 
           
           RowBox[{"\"\<Too few points in fit window for \>\"", ",", "id", 
            ",", "\"\<: \>\"", ",", 
            RowBox[{"Length", "[", "dataFit", "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Return", "[", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<id\>\"", "->", "id"}], ",", 
             RowBox[{"\"\<status\>\"", "->", "\"\<too_few_points\>\""}], ",", 
             RowBox[{"\"\<file\>\"", "->", 
              RowBox[{"FileNameTake", "[", "file", "]"}]}], ",", 
             RowBox[{"\"\<trueWL_nm\>\"", "->", "trueWL"}], ",", 
             RowBox[{"\"\<fitWindow\>\"", "->", 
              RowBox[{"ToString", "[", "window", "]"}]}], ",", 
             RowBox[{"\"\<observed_mu_nm\>\"", "->", 
              RowBox[{"Missing", "[", "\"\<NoFit\>\"", "]"}]}], ",", 
             RowBox[{"\"\<sigmu_nm\>\"", "->", 
              RowBox[{"Missing", "[", "\"\<NoFit\>\"", "]"}]}]}], "|>"}], 
           "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"CurveFit", " ", "global", " ", "variables"}], "*)"}], 
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "dataFit", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"xx", "=", 
        RowBox[{"dataFit", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yy", "=", 
        RowBox[{"dataFit", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sx", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0.", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sy", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0.", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Fitting \>\"", ",", "id", ",", "\"\< with n = \>\"", ",",
          "n", ",", "\"\< points.\>\""}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<File: \>\"", ",", 
         RowBox[{"FileNameTake", "[", "file", "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Window: \>\"", ",", "window"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Quiet", "[", 
        RowBox[{
         RowBox[{"GaussianLFit", "[", "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"SetOptions", "::", "optnf"}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"params", "=", 
        RowBox[{"getFitParams", "[", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"report", "=", 
        RowBox[{"Quiet", "[", 
         RowBox[{
          RowBox[{"LinearDifferencePlot", "[", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"SetOptions", "::", "optnf"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"titledReport", "=", 
        RowBox[{"Labeled", "[", 
         RowBox[{"report", ",", 
          RowBox[{"Style", "[", 
