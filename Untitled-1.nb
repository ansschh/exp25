       RowBox[{"SortBy", "[", 
        RowBox[{"d", ",", "First"}], "]"}]}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"baselineSubtractNormalize", "[", "data_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "x", ",", "y", ",", "nEdge", ",", "base", ",", "y0", ",", "amp"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", ",", "y"}], "}"}], "=", 
        RowBox[{"Transpose", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"nEdge", "=", 
        RowBox[{"Max", "[", 
         RowBox[{"3", ",", 
          RowBox[{"Min", "[", 
           RowBox[{"10", ",", 
            RowBox[{"Floor", "[", 
             RowBox[{
              RowBox[{"Length", "[", "data", "]"}], "/", "8"}], "]"}]}], 
           "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"base", "=", 
        RowBox[{"Mean", "@", 
         RowBox[{"Join", "[", 
          RowBox[{
           RowBox[{"Take", "[", 
            RowBox[{"y", ",", "nEdge"}], "]"}], ",", 
           RowBox[{"Take", "[", 
            RowBox[{"y", ",", 
             RowBox[{"-", "nEdge"}]}], "]"}]}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"y0", "=", 
        RowBox[{"y", "-", "base"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"amp", "=", 
        RowBox[{"Max", "[", "y0", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"amp", "<=", "0"}], ",", 
         RowBox[{"amp", "=", "1.0"}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"x", ",", 
          RowBox[{"y0", "/", "amp"}]}], "}"}], "]"}]}]}], "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
