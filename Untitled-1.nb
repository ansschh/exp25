                RowBox[{"y", "+", "#2"}]}], "}"}]}]}], ")"}], "&"}], ",", 
          RowBox[{"{", 
           RowBox[{"procData", ",", "offsets"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"colors", "=", 
