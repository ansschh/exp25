             RowBox[{"\"\<status\>\"", "->", "\"\<too_few_points\>\""}]}], 
            "|>"}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"xvals", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yvals", "=", 
