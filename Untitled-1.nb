            CurveFit`CheckLength[]], 
           Abort[], CurveFit`Private`fpxx[
              Pattern[CurveFit`x, 
               Blank[]], 
              Pattern[CurveFit`Private`y, 
               Blank[]]] = D[
              CurveFit`xnew[CurveFit`x, CurveFit`Private`y], CurveFit`x]; 
           CurveFit`Private`fpxy[
              Pattern[CurveFit`x, 
               Blank[]], 
              Pattern[CurveFit`Private`y, 
               Blank[]]] = D[
              CurveFit`xnew[CurveFit`x, CurveFit`Private`y], 
              CurveFit`Private`y]; CurveFit`Private`fpyx[
              Pattern[CurveFit`x, 
               Blank[]], 
              Pattern[CurveFit`Private`y, 
               Blank[]]] = D[
              CurveFit`ynew[CurveFit`x, CurveFit`Private`y], CurveFit`x]; 
           CurveFit`Private`fpyy[
              Pattern[CurveFit`x, 
