 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fitOneHg", "[", "spec_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "file", ",", "dataFull", ",", "data", ",", "xvals", ",", "yvals", ",", 
        "xmin", ",", "xmax", ",", "c0", ",", "d0", ",", "amp0", ",", "mu0", ",",
         "sig0", ",", "x0", ",", "fit", ",", "params", ",", "errs", ",", 
        "resid", ",", "rms", ",", "maxresid", ",", "fitPlot", ",", 
        "residPlot", ",", "table", ",", "report", ",", "outFile", ",", "c", ",",
         "d", ",", "amp", ",", "mu", ",", "sig", ",", "x"}], "}"}], ",", 
      RowBox[{
       RowBox[{"file", "=", 
        RowBox[{"findFile", "[", 
         RowBox[{"spec", "[", "\"\<fileKey\>\"", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"MissingQ", "[", "file", "]"}], ",", 
