              Pattern[CurveFit`Private`y, 
               Blank[]]] = D[
              CurveFit`ynew[CurveFit`x, CurveFit`Private`y], 
              CurveFit`Private`y]; 
           CurveFit`Private`xxnew = 
            CurveFit`xx 0 + 1. CurveFit`xnew[CurveFit`xx, CurveFit`yy]; 
           CurveFit`Private`sxnew = 
            Sqrt[(CurveFit`Private`fpxx[CurveFit`xx, CurveFit`yy] 1. 
                CurveFit`sx)^2 + (
                CurveFit`Private`fpxy[CurveFit`xx, CurveFit`yy] 1. 
                CurveFit`sy)^2]; 
           CurveFit`Private`yynew = 
            CurveFit`yy 0 + 1. CurveFit`ynew[CurveFit`xx, CurveFit`yy]; 
           CurveFit`Private`synew = 
            Sqrt[(CurveFit`Private`fpyx[CurveFit`xx, CurveFit`yy] 1. 
                CurveFit`sx)^2 + (
                CurveFit`Private`fpyy[CurveFit`xx, CurveFit`yy] 1. 
                CurveFit`sy)^2]; If[$MessageList != {}, Message[
               MessageName[CurveFit`DataTransform, "error"]]; Abort[]; Null, 
             If[
              Or[NumberQ[
                 Part[CurveFit`Private`xxnew, 1]] != True, NumberQ[
                 Part[CurveFit`Private`sxnew, 1]] != True, NumberQ[
                 Part[CurveFit`Private`yynew, 1]] != True, NumberQ[
                 Part[CurveFit`Private`synew, 1]] != True], Message[
                MessageName[CurveFit`DataTransform, "D"]]; Abort[], 
              CurveFit`SaveForUndo[]; CurveFit`xx = CurveFit`Private`xxnew; 
              CurveFit`sx = CurveFit`Private`sxnew; 
              CurveFit`yy = CurveFit`Private`yynew; 
              CurveFit`sy = CurveFit`Private`synew; 
              If[CurveFit`Private`display, Print[
                  TableForm[
                   
                   Join[{{"point", "x", "y", "\!\(\[Sigma]\_y\)", 
                    "\!\(\[Sigma]\_x\)"}}, 
                    Transpose[{
                    Range[CurveFit`n], CurveFit`xx, CurveFit`yy, CurveFit`sy, 
                    CurveFit`sx}]]]]; Null, 
                Print["All ", CurveFit`n, " points transformed."]; Null, 
                Message[
                 MessageName[CurveFit`DisplayResults, "unknown"]]]; Null]]]; 
         Null]}], "SubValues" -> None, "DefaultValues" -> None, "NValues" -> 
