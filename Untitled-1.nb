 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"makeCurveFitPDF", "[", "file_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "data", ",", "category", ",", "outDir", ",", "outFile", ",", "plot"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"data", "=", 
        RowBox[{"Import", "[", 
         RowBox[{"file", ",", "\"\<Table\>\""}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"data", "=", 
        RowBox[{"Cases", "[", 
         RowBox[{"data", ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"x_", "?", "NumericQ"}], ",", 
             RowBox[{"y_", "?", "NumericQ"}], ",", "___"}], "}"}], ":>", 
           RowBox[{"{", 
            RowBox[{"x", ",", "y"}], "}"}]}], ",", "Infinity"}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "data", "]"}], "<", "3"}], ",", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<Skipping bad file: \>\"", ",", 
            RowBox[{"FileNameTake", "[", "file", "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"CurveFit", " ", "global", " ", "variables"}], "*)"}], 
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"xx", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yy", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sx", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0.", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sy", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0.", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"category", "=", 
        RowBox[{
         RowBox[{"FileNameSplit", "[", 
          RowBox[{"DirectoryName", "[", "file", "]"}], "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"-", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"outDir", "=", 
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"pdfRoot", ",", "category"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"DirectoryQ", "[", "outDir", "]"}]}], ",", 
         RowBox[{"CreateDirectory", "[", "outDir", "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"plot", "=", 
        RowBox[{"Quiet", "[", 
         RowBox[{
          RowBox[{"LinearDataPlot", "[", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"SetOptions", "::", "optnf"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"outFile", "=", 
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"outDir", ",", 
           RowBox[{
            RowBox[{"FileBaseName", "[", "file", "]"}], 
            "<>", "\"\<.pdf\>\""}]}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Export", "[", 
        RowBox[{"outFile", ",", "plot", ",", "\"\<PDF\>\""}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Saved: \>\"", ",", "outFile"}], "]"}], ";", 
       "\[IndentingNewLine]", "outFile"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
