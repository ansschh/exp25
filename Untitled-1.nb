             "Black", ",", 
            RowBox[{"FontFamily", "->", "\"\<Times\>\""}]}], "]"}], ",", 
          "Top"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"outFile", "=", 
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"fitReportDir", ",", 
           RowBox[{
            RowBox[{"makeOutName", "[", "id", "]"}], 
            "<>", "\"\<_GaussianLFit_report.pdf\>\""}]}], "}"}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"Export", "[", 
        RowBox[{"outFile", ",", "titledReport", ",", "\"\<PDF\>\""}], "]"}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"result", "=", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<id\>\"", "->", "id"}], ",", 
          RowBox[{"\"\<status\>\"", "->", "\"\<fit_complete\>\""}], ",", 
          RowBox[{"\"\<file\>\"", "->", 
           RowBox[{"FileNameTake", "[", "file", "]"}]}], ",", 
          RowBox[{"\"\<trueWL_nm\>\"", "->", "trueWL"}], ",", 
          RowBox[{"\"\<fit_xmin_nm\>\"", "->", 
           RowBox[{"window", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], ",", 
          RowBox[{"\"\<fit_xmax_nm\>\"", "->", 
           RowBox[{"window", "[", 
            RowBox[{"[", "2", "]"}], "]"}]}], ",", 
          RowBox[{"\"\<n_fit_points\>\"", "->", "n"}], ",", 
          RowBox[{"\"\<observed_mu_nm\>\"", "->", 
           RowBox[{"params", "[", "\"\<mu\>\"", "]"}]}], ",", 
          RowBox[{"\"\<sigmu_nm\>\"", "->", 
           RowBox[{"params", "[", "\"\<sigmu\>\"", "]"}]}], ",", 
          RowBox[{"\"\<gaussian_sigma_nm\>\"", "->", 
           RowBox[{"params", "[", "\"\<sigma\>\"", "]"}]}], ",", 
          RowBox[{"\"\<sigsigma_nm\>\"", "->", 
           RowBox[{"params", "[", "\"\<sigsigma\>\"", "]"}]}], ",", 
          RowBox[{"\"\<amplitude_ymax\>\"", "->", 
           RowBox[{"params", "[", "\"\<ymax\>\"", "]"}]}], ",", 
          RowBox[{"\"\<background_c\>\"", "->", 
           RowBox[{"params", "[", "\"\<c\>\"", "]"}]}], ",", 
          RowBox[{"\"\<background_slope_d\>\"", "->", 
           RowBox[{"params", "[", "\"\<d\>\"", "]"}]}], ",", 
          RowBox[{"\"\<residual_stdv\>\"", "->", 
           RowBox[{"params", "[", "\"\<stdv\>\"", "]"}]}], ",", 
          RowBox[{"\"\<useForCalibration\>\"", "->", 
           RowBox[{"spec", "[", "\"\<useForCalibration\>\"", "]"}]}], ",", 
          RowBox[{"\"\<fit_report_pdf\>\"", "->", "outFile"}]}], "|>"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
