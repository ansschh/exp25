     ",", "\"\< converted data files.\>\""}], "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"makePDF", "[", "file_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "data", ",", "category", ",", "outDir", ",", "outFile", ",", "plot"}], 
       "}"}], ",", 
      RowBox[{
       RowBox[{"data", "=", 
        RowBox[{"Import", "[", 
         RowBox[{"file", ",", "\"\<Table\>\""}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"data", "=", 
        RowBox[{"Cases", "[", 
         RowBox[{"data", ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"x_", "?", "NumericQ"}], ",", 
             RowBox[{"y_", "?", "NumericQ"}], ",", "___"}], "}"}], ":>", 
           RowBox[{"{", 
            RowBox[{"x", ",", "y"}], "}"}]}], ",", "Infinity"}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"category", "=", 
        RowBox[{
         RowBox[{"FileNameSplit", "[", 
          RowBox[{"DirectoryName", "[", "file", "]"}], "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"-", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"outDir", "=", 
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"pdfRoot", ",", "category"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"DirectoryQ", "[", "outDir", "]"}]}], ",", 
         RowBox[{"CreateDirectory", "[", "outDir", "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"outFile", "=", 
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"outDir", ",", 
           RowBox[{
            RowBox[{"FileBaseName", "[", "file", "]"}], 
            "<>", "\"\<.pdf\>\""}]}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"plot", "=", 
        RowBox[{"ListPlot", "[", 
         RowBox[{"data", ",", 
          RowBox[{"Frame", "->", "True"}], ",", 
          RowBox[{"PlotRange", "->", "All"}], ",", 
          RowBox[{"ImageSize", "->", "900"}], ",", 
          RowBox[{"FrameLabel", "->", 
           RowBox[{"{", 
            
            RowBox[{"\"\<Real wavelength (nm)\>\"", 
             ",", "\"\<Signal (V)\>\""}], "}"}]}], ",", 
          RowBox[{"PlotLabel", "->", 
           RowBox[{"FileBaseName", "[", "file", "]"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Export", "[", 
        RowBox[{"outFile", ",", "plot", ",", "\"\<PDF\>\""}], "]"}], ";", 
       "\[IndentingNewLine]", "outFile"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
