 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"makeStackedPlot", "[", 
     RowBox[{
     "category_String", ",", "mainTitle_String", ",", "outStem_String", ",", 
      RowBox[{"spacing_", ":", "1.35"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "folder", ",", "files", ",", "rawData", ",", "procData", ",", 
        "centers", ",", "order", ",", "labels", ",", "offsets", ",", 
        "shifted", ",", "colors", ",", "xMin", ",", "xMax", ",", "yMax", ",", 
        "legend", ",", "plot", ",", "outPDF", ",", "outPNG"}], "}"}], ",", 
      RowBox[{
       RowBox[{"folder", "=", 
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"dataRoot", ",", "category"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"files", "=", 
        RowBox[{"FileNames", "[", 
         RowBox[{"\"\<*_REAL_FOR_CURVEFIT.dat\>\"", ",", "folder"}], "]"}]}], 
       ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "files", "]"}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<No files found in: \>\"", ",", "folder"}], "]"}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rawData", "=", 
        RowBox[{"importNumeric", "/@", "files"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"procData", "=", 
        RowBox[{"baselineSubtractNormalize", "/@", "rawData"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"centers", "=", 
        RowBox[{"peakCenter", "/@", "procData"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"order", "=", 
        RowBox[{"Ordering", "[", "centers", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"files", "=", 
        RowBox[{"files", "[", 
         RowBox[{"[", "order", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"rawData", "=", 
        RowBox[{"rawData", "[", 
         RowBox[{"[", "order", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"procData", "=", 
        RowBox[{"procData", "[", 
         RowBox[{"[", "order", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"centers", "=", 
        RowBox[{"centers", "[", 
         RowBox[{"[", "order", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"labels", "=", 
        RowBox[{"MapThread", "[", 
         RowBox[{"shortLabel", ",", 
          RowBox[{"{", 
           RowBox[{"files", ",", "centers"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"offsets", "=", 
