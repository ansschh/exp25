            RowBox[{"\"\<Trace   Peak center\>\"", ",", "11", ",", "Bold"}], 
            "]"}]}], ",", 
          RowBox[{"LabelStyle", "->", 
           RowBox[{"Directive", "[", "11", "]"}]}], ",", 
