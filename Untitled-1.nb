     RowBox[{"Length", "[", "files", "]"}], 
     ",", "\"\< converted data files.\>\""}], "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"makeTitledCurveFitPDF", "[", "file_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "data", ",", "category", ",", "outDir", ",", "outFile", ",", 
        "baseTitle", ",", "plot", ",", "titledPlot"}], "}"}], ",", 
      RowBox[{
       RowBox[{"data", "=", 
        RowBox[{"Import", "[", 
         RowBox[{"file", ",", "\"\<Table\>\""}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"data", "=", 
        RowBox[{"Cases", "[", 
         RowBox[{"data", ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"x_", "?", "NumericQ"}], ",", 
             RowBox[{"y_", "?", "NumericQ"}], ",", "___"}], "}"}], ":>", 
           RowBox[{"{", 
            RowBox[{"x", ",", "y"}], "}"}]}], ",", "Infinity"}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "data", "]"}], "<", "3"}], ",", 
         RowBox[{
          RowBox[{"Print", "[", 
           RowBox[{"\"\<Skipping bad file: \>\"", ",", 
            RowBox[{"FileNameTake", "[", "file", "]"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"CurveFit", " ", "globals"}], "*)"}], 
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"xx", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"yy", "=", 
        RowBox[{"data", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"sx", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0.", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"sy", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0.", ",", "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"category", "=", 
        RowBox[{
         RowBox[{"FileNameSplit", "[", 
          RowBox[{"DirectoryName", "[", "file", "]"}], "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"-", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"outDir", "=", 
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"pdfRoot", ",", "category"}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"DirectoryQ", "[", "outDir", "]"}]}], ",", 
         RowBox[{"CreateDirectory", "[", "outDir", "]"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"baseTitle", "=", 
        RowBox[{"FileBaseName", "[", "file", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"plot", "=", 
        RowBox[{"Quiet", "[", 
         RowBox[{
          RowBox[{"LinearDataPlot", "[", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"SetOptions", "::", "optnf"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"titledPlot", "=", 
        RowBox[{"Labeled", "[", 
         RowBox[{"plot", ",", 
          RowBox[{"Style", "[", 
           RowBox[{"baseTitle", ",", "12", ",", "Italic", ",", "Black", ",", 
            RowBox[{"FontFamily", "->", "\"\<Times\>\""}]}], "]"}], ",", 
          "Top"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"outFile", "=", 
        RowBox[{"FileNameJoin", "[", 
         RowBox[{"{", 
          RowBox[{"outDir", ",", 
           RowBox[{"baseTitle", "<>", "\"\<.pdf\>\""}]}], "}"}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"Export", "[", 
        RowBox[{"outFile", ",", "titledPlot", ",", "\"\<PDF\>\""}], "]"}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Saved: \>\"", ",", "outFile"}], "]"}], ";", 
       "\[IndentingNewLine]", "outFile"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"exported", "=", 
    RowBox[{"DeleteCases", "[", 
     RowBox[{
      RowBox[{"makeTitledCurveFitPDF", "/@", "files"}], ",", "$Failed"}], 
     "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<DONE. Exported \>\"", ",", 
    RowBox[{"Length", "[", "exported", "]"}], ",", "\"\< titled PDFs.\>\""}], 
   "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Print", "[", "\"\<Saved here:\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", "pdfRoot", "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
