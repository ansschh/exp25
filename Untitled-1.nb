          CurveFit`Private`display}, 
         CurveFit`Private`display = OptionValue[CurveFit`DisplayResults]; 
         If[CurveFit`Private`display, Null, Null, Message[
             MessageName[CurveFit`DisplayResults, "unknown"], 
             CurveFit`Private`display, True]; CurveFit`Private`display = True; 
           Null]; If[
